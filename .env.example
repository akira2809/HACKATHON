# Copy this file to `.env.local` for local development.
# Recommended: keep provider keys server-side.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional browser-only fallbacks for local hackathon demos.
# Avoid shipping real secrets with any `NEXT_PUBLIC_` variable.
NEXT_PUBLIC_OPENAI_API_KEY=
NEXT_PUBLIC_OPENAI_MODEL=gpt-4.1-mini
NEXT_PUBLIC_ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_VOICE_ID=
NEXT_PUBLIC_ELEVENLABS_MODEL_ID=eleven_multilingual_v2
